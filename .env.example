# ---- AI (server-side only; powers "What is this about?" + web-search verification) ----
# Read by the local dev server middleware (vite.config.js) and the Vercel function at /api/ai.
# NEVER prefix this with VITE_ — that would expose it to the browser.
# Local: put it in a file named  .env  next to package.json, then restart the app.
# Vercel: add it under Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-your-key

# ---- Optional: Supabase (auth + saved events). App runs fully without these in demo mode. ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
